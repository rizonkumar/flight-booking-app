# Flight Service (backend/flight-service/.env)
PORT=4000

# Booking Service (backend/booking-service/.env)
PORT=4001
FLIGHT_SERVICE=http://localhost:4000

# Frontend (frontend/.env.local)
NEXT_PUBLIC_FLIGHT_SERVICE_URL=http://localhost:4000
NEXT_PUBLIC_BOOKING_SERVICE_URL=http://localhost:4001

# Database — update config.json in each service's src/config/
# Default DB names: flights_db, flights_booking_db
